VITE_API_URL=http://localhost:3000/api
VITE_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
# "false" switches RTK Query from the in-memory mocks to the real API above.
VITE_USE_MOCKS=true
# Yandex Geocoder key — backend-only (no VITE_ prefix on purpose: Vite must never
# bundle it into the client; geocoding calls go through the backend, which reads
# it from process.env). See BACKEND_INSTRUCTIONS.md, "Yandex Geocoder" section.
YANDEX_GEOCODER_API_KEY=your-yandex-geocoder-api-key
